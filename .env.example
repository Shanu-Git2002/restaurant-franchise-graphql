# Root environment variables for Docker Compose

# PostgreSQL
POSTGRES_DB=franchise_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password-here

# Redis
REDIS_PASSWORD=your-redis-password-here

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=your-64-char-access-secret-here
JWT_REFRESH_SECRET=your-64-char-refresh-secret-here

# Frontend URLs (for CORS)
CORS_ORIGINS=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Vite frontend
VITE_GRAPHQL_URL=https://api.yourdomain.com/graphql
VITE_WS_URL=wss://api.yourdomain.com/graphql
